<div class="auth-container">
  <div class="auth-box">
    <div class="auth-header">
      <i class="fas fa-sign-in-alt"></i>
      <h2>Member Login</h2>
    </div>
    
    <% if (error) { %>
      <div class="flash-message flash-error">
        <i class="fas fa-exclamation-triangle"></i> <%= error %>
      </div>
    <% } %>
    
    <form action="/login" method="POST" class="auth-form" data-testid="form-login">
      <div class="form-group">
        <label for="username"><i class="fas fa-user"></i> Username:</label>
        <input type="text" id="username" name="username" required minlength="3" maxlength="20" data-testid="input-username">
      </div>
      
      <div class="form-group">
        <label for="password"><i class="fas fa-lock"></i> Password:</label>
        <input type="password" id="password" name="password" required minlength="4" data-testid="input-password">
      </div>
      
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" data-testid="button-login">
          <i class="fas fa-sign-in-alt"></i> Log In
        </button>
      </div>
    </form>
    
    <div class="auth-footer">
      <p>Don't have an account? <a href="/register" data-testid="link-register">Register here</a></p>
      <p><a href="/" data-testid="link-browse-guest">Browse as Guest</a></p>
    </div>
    
    <div class="auth-hint">
      <h4><i class="fas fa-info-circle"></i> Demo Accounts</h4>
      <p>Admin access: <strong>Administrator</strong> / <strong>admin123</strong></p>
      <p style="font-size: 10px; color: #888;">Other demo accounts don't have passwords set.</p>
    </div>
  </div>
</div>

<style>
.auth-container {
  display: flex;
  justify-content: center;
  padding: 30px 20px;
}

.auth-box {
  background: #fff;
  border: 1px solid #bbb;
  max-width: 400px;
  width: 100%;
}

.auth-header {
  background: linear-gradient(to bottom, #3366cc 0%, #003399 100%);
  color: #fff;
  padding: 12px 15px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.auth-header h2 {
  margin: 0;
  font-size: 14px;
}

.auth-form {
  padding: 20px;
}

.auth-form .form-group {
  margin-bottom: 15px;
}

.auth-form label {
  display: block;
  margin-bottom: 5px;
  font-weight: bold;
  font-size: 12px;
  color: #333;
}

.auth-form input {
  width: 100%;
  padding: 8px;
  border: 1px solid #ccc;
  font-size: 12px;
  box-sizing: border-box;
}

.auth-form input:focus {
  outline: none;
  border-color: #3366cc;
}

.form-actions {
  margin-top: 20px;
}

.auth-footer {
  padding: 15px 20px;
  background: #f5f5f5;
  border-top: 1px solid #ddd;
  text-align: center;
  font-size: 11px;
}

.auth-footer p {
  margin: 5px 0;
}

.auth-hint {
  padding: 15px 20px;
  background: #fffbcc;
  border-top: 1px solid #e0d090;
  font-size: 11px;
}

.auth-hint h4 {
  margin: 0 0 8px 0;
  font-size: 12px;
  color: #666;
}

.auth-hint p {
  margin: 3px 0;
}
</style>

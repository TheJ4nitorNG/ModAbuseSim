<div class="auth-container">
  <div class="auth-box">
    <div class="auth-header">
      <i class="fas fa-user-plus"></i>
      <h2>New Member Registration</h2>
    </div>
    
    <% if (error) { %>
      <div class="flash-message flash-error">
        <i class="fas fa-exclamation-triangle"></i> <%= error %>
      </div>
    <% } %>
    
    <div class="registration-notice">
      <i class="fas fa-exclamation-circle"></i>
      <span>
        By registering, you agree to follow our <a href="/rules">Forum Rules</a>. 
        Moderators reserve the right to take action for any reason. Or no reason. 
        Such is the way of forums.
      </span>
    </div>
    
    <form action="/register" method="POST" class="auth-form" data-testid="form-register">
      <div class="form-group">
        <label for="username"><i class="fas fa-user"></i> Username:</label>
        <input type="text" id="username" name="username" required minlength="3" maxlength="20" 
               pattern="[a-zA-Z0-9_]+" title="Letters, numbers, and underscores only" data-testid="input-username">
        <small>3-20 characters, letters/numbers/underscores only</small>
      </div>
      
      <div class="form-group">
        <label for="password"><i class="fas fa-lock"></i> Password:</label>
        <input type="password" id="password" name="password" required minlength="4" data-testid="input-password">
        <small>At least 4 characters</small>
      </div>
      
      <div class="form-group">
        <label for="confirm_password"><i class="fas fa-lock"></i> Confirm Password:</label>
        <input type="password" id="confirm_password" name="confirm_password" required minlength="4" data-testid="input-confirm-password">
      </div>
      
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" data-testid="button-register">
          <i class="fas fa-user-plus"></i> Create Account
        </button>
      </div>
    </form>
    
    <div class="auth-footer">
      <p>Already have an account? <a href="/login" data-testid="link-login">Log in here</a></p>
    </div>
  </div>
</div>

<style>
.auth-container {
  display: flex;
  justify-content: center;
  padding: 30px 20px;
}

.auth-box {
  background: #fff;
  border: 1px solid #bbb;
  max-width: 400px;
  width: 100%;
}

.auth-header {
  background: linear-gradient(to bottom, #3366cc 0%, #003399 100%);
  color: #fff;
  padding: 12px 15px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.auth-header h2 {
  margin: 0;
  font-size: 14px;
}

.registration-notice {
  padding: 12px 15px;
  background: #fff8dc;
  border-bottom: 1px solid #e0d090;
  font-size: 11px;
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.registration-notice i {
  color: #cc8800;
  margin-top: 2px;
}

.auth-form {
  padding: 20px;
}

.auth-form .form-group {
  margin-bottom: 15px;
}

.auth-form label {
  display: block;
  margin-bottom: 5px;
  font-weight: bold;
  font-size: 12px;
  color: #333;
}

.auth-form input {
  width: 100%;
  padding: 8px;
  border: 1px solid #ccc;
  font-size: 12px;
  box-sizing: border-box;
}

.auth-form input:focus {
  outline: none;
  border-color: #3366cc;
}

.auth-form small {
  display: block;
  margin-top: 3px;
  font-size: 10px;
  color: #888;
}

.form-actions {
  margin-top: 20px;
}

.auth-footer {
  padding: 15px 20px;
  background: #f5f5f5;
  border-top: 1px solid #ddd;
  text-align: center;
  font-size: 11px;
}

.auth-footer p {
  margin: 5px 0;
}
</style>
